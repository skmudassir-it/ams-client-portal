# ─────────────────────────────────────────────
# AMS Client Portal — Environment Variables
# Copy to .env.local and fill in real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────

# Database (SQLite file-based for local dev)
# For production, consider Turso SQLite or Vercel Postgres
DATABASE_URL="file:./dev.db"

# NextAuth.js v5 (Auth.js)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-generated-secret-here-replace-me"

# Base URL for auth callbacks
# Local: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
AUTH_URL="http://localhost:3000"

# Optional — Email provider (for password reset, notifications, etc.)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="noreply@ams-it-services.com"
# SMTP_PASS="your-smtp-password"
# EMAIL_FROM="noreply@ams-it-services.com"
